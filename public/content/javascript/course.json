              "code": "class AppError extends Error {\n  constructor(message, code) {\n    super(message);\n    this.name = 'AppError';\n    this.code = code;\n  }\n}\n\nasync function submitForm(data) {\n  try {\n    const result = await postData('/api/submit', data);\n    return result;\n  } catch (error) {\n    if (error instanceof AppError) {\n      showUserError(error.message);\n    } else {\n      logError(error);\n      throw error;\n    }\n  }\n}"
            }
