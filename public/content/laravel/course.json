              "id": "n1-query-problem"
            },
            {
              "type": "code",
              "language": "php",
              "code": "// Wrong — 1 + N queries\n$orders = Order::all();\nforeach ($orders as $order) {\n    echo $order->user->name; // Query per iteration!\n}\n\n// Correct — 2 queries total\n$orders = Order::with('user')->paginate(20);"
            }
          ],
