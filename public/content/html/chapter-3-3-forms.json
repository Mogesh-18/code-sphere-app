          "text": "Basic Form Structure",
          "id": "basic-form-structure"
        },
        {
          "type": "code",
          "language": "html",
          "code": "<form action=\"/submit\" method=\"POST\" novalidate>\n  <div class=\"form-group\">\n    <label for=\"full-name\">Full Name *</label>\n    <input\n      type=\"text\"\n      id=\"full-name\"\n      name=\"fullName\"\n      autocomplete=\"name\"\n      required\n      aria-required=\"true\"\n    />\n  </div>\n  <button type=\"submit\">Submit</button>\n</form>"
        }
      ],
