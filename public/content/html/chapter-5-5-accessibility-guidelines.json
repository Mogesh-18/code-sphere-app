      "title": "WCAG Fundamentals",
      "order": 2,
      "content": [
        {
          "type": "heading",
          "level": 2,
          "text": "WCAG Fundamentals",
          "id": "wcag-fundamentals"
        },
        {
          "type": "paragraph",
          "children": [
            {
              "type": "text",
              "value": "WCAG 2.1 is organised around four principles: "
            },
            {
              "type": "strong",
              "children": [
                {
                  "type": "text",
                  "value": "Perceivable, Operable, Understandable, Robust"
                }
              ]
            },
            {
              "type": "text",
              "value": " (POUR)."
            }
          ]
        },
        {
          "type": "paragraph",
          "children": [
            {
              "type": "text",
              "value": "Conformance levels:"
            }
          ]
        },
        {
          "type": "list",
          "ordered": false,
          "items": [
            {
              "children": [
                {
                  "type": "paragraph",
                  "children": [
                    {
                      "type": "strong",
                      "children": [
                        {
                          "type": "text",
                          "value": "Level A"
                        }
                      ]
                    },
                    {
                      "type": "text",
                      "value": " — Minimum. Must be met."
                    }
                  ]
                }
              ]
            },
            {
              "children": [
                {
                  "type": "paragraph",
                  "children": [
                    {
                      "type": "strong",
                      "children": [
                        {
                          "type": "text",
                          "value": "Level AA"
                        }
                      ]
                    },
                    {
                      "type": "text",
                      "value": " — Standard. Required by most laws."
                    }
                  ]
                }
              ]
            },
            {
              "children": [
                {
                  "type": "paragraph",
                  "children": [
                    {
                      "type": "strong",
                      "children": [
                        {
                          "type": "text",
                          "value": "Level AAA"
                        }
                      ]
                    },
                    {
                      "type": "text",
                      "value": " — Enhanced. Not required for all content."
                    }
                  ]
                }
              ]
            }
          ]
        }
      ],
