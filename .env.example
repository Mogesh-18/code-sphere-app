# AI Provider Configuration
# Option 1: OpenRouter (free models available)
OPENROUTER_API_KEY=your_key_here
OPENROUTER_MODEL=mistralai/mistral-7b-instruct:free

# Option 2: Ollama (completely free, local)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral

# Option 3: Groq (free tier)
GROQ_API_KEY=your_key_here
GROQ_MODEL=llama3-8b-8192

# Active AI provider: 'openrouter' | 'ollama' | 'groq'
NEXT_PUBLIC_AI_PROVIDER=ollama

# App config
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=DevLearn
